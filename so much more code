def heading_to_html(block):
    headcount = 0
    while block[headcount] == "#":
        headcount = headcount + 1 
    block = block.lstrip("#").strip()
    parent_node = ParentNode(f"h{headcount}",text_to_children(block))
    #print(parent_node.to_html())
    return parent_node

def code_to_html(block):
    lines = block.split("\n")
    middle = lines[1:-1]
    content = "\n".join(middle) + "\n"
    node = TextNode(content,TextType.TEXT)
    html = text_node_to_html_node(node)
    code_html = ParentNode("code",[html])
    parent_node = ParentNode("pre",[code_html])
    #print(parent_node.to_html())
    return parent_node
    
def quote_to_html(block):
    lines = block.split("\n")
    cleaned = []
    for line in lines:
        line = line.lstrip(">").strip()
        cleaned.append(line)
    text = " ".join(cleaned)
    children = text_to_children(text)
    parent_node = ParentNode("blockquote",[children])
    #print(parent_node.to_html())
    return parent_node
    
def unordered_list_to_html(block):
    lines = block.split("\n")
    html_nodes = []
    for line in lines:
        line = line[2:]
        html_nodes.append(ParentNode("li",text_to_children(line)))
    parent_node = ParentNode("ul",html_nodes)
    #print(parent_node.to_html())
    return parent_node
    
def ordered_list_to_html(block):
    lines = block.split("\n")
    html_nodes = []
    for line_n, line in enumerate(lines):
        line = line[len(f"{line_n}") + 2:]
        html_nodes.append(ParentNode("li",text_to_children(line)))
    parent_node = ParentNode("ol",html_nodes)
    print(parent_node.to_html())
    return parent_node
    
def text_to_children(text):
